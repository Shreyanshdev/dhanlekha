							{ "key": "Authorization", "value": "Bearer {{JWT_TOKEN}}" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Cashier One\",\n    \"email\": \"cashier1@supermart.com\",\n    \"password\": \"cashier123\",\n    \"role\": \"cashier\"\n}",
