		{
			"name": "Auth",
			"item": [
				{
					"name": "Register Tenant",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"tenantName\": \"Super Mart\",\n    \"tenantEmail\": \"admin@supermart.com\",\n    \"phone\": \"9876543210\",\n    \"planId\": \"starter\",\n    \"userName\": \"Admin\",\n    \"password\": \"securepassword123\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": {
							"raw": "{{BASE_URL}}/auth/register",
							"host": ["{{BASE_URL}}"],
							"path": ["auth", "register"]
						}
					},
					"response": []
				},
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.success && jsonData.data.token) {",
									"    pm.collectionVariables.set('JWT_TOKEN', jsonData.data.token);",
									"    console.log('Token auto-saved to JWT_TOKEN variable');",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"admin@supermart.com\",\n    \"password\": \"securepassword123\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": {
							"raw": "{{BASE_URL}}/auth/login",
							"host": ["{{BASE_URL}}"],
							"path": ["auth", "login"]
						}
					},
					"response": []
				}
			]
		},
